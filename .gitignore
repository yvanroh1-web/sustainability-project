# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ────────────────────────────────────────────────
.ipynb_checkpoints/
