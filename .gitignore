# ── Data files (large raw Excel files — not committed) ─────
data/raw/*.xlsx
data/raw/*.zip
data/raw/extracted/
data/processed/

# ── Output artefacts (reproducible from notebook) ──────────
output/
results/tables/*.csv
results/figures/*.png
results/figures/*.pdf

# ── OS & editors ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Secrets / local config ─────────────────────────────────
config/paths.json
*.env
